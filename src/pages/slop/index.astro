---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SlopReport from '../../components/SlopReport.astro';
import { getSlopReports } from '../../lib/slopReports.ts';

const pageTitle = 'Slop';
const reports = getSlopReports();
---

<BaseLayout pageTitle={pageTitle}>
    <p>
        Throwaway HTML reports. AI is getting good at writing these and I wanted a convenient way to share them.
    </p>

    {reports.length > 0 && (
        <label>
            Search
            <input id="slop-search" type="search" placeholder="Filter by title or filename..." />
        </label>
    )}

    {reports.length === 0 ? (
        <p><i>No slop yet.</i></p>
    ) : (
        <ul id="slop-list">
            {reports.map((report) => <SlopReport report={report} />)}
        </ul>
    )}

    {reports.length > 0 && (
        <script>
            import '../../scripts/slop-search.js';
        </script>
    )}
</BaseLayout>
